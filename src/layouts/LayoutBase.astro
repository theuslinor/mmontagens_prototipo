---
// src/layouts/LayoutBase.astro
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&family=Oswald:wght@700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Montserrat', 'sans-serif'],
                        condensed: ['Oswald', 'sans-serif'],
                    },
                    colors: {
                        mm: {
                            blue: '#1489c8',
                            cyan: '#19a1cd',
                            darkblue: '#0d5d9c',
                            yellow: '#fbc02d',
                            footer: '#1a1a1a',
                        }
                    }
                }
            }
        }
    </script>

    <style is:global>
        @keyframes cart-bounce {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.4); }
        }

        .animate-bounce-cart {
            animation: cart-bounce 0.4s ease-in-out;
        }

        .clip-slant {
            clip-path: polygon(0 15%, 100% 0, 100% 100%, 0% 100%);
        }
    </style>
</head>

<body class="font-sans antialiased text-gray-800 bg-white overflow-x-hidden">

    <header class="w-full bg-white h-[90px] md:h-[100px] flex items-center justify-between px-6 lg:px-24 shadow-sm relative z-[100]">
        <a href="/" class="flex items-center justify-center transition hover:scale-105">
            <img src="/midia/logo4.png" alt="MM Montagens" class="w-[130px] md:w-[160px] h-auto object-contain">
        </a>

        <nav class="hidden md:flex items-center gap-8 text-[14px] font-semibold">
            <a href="/" class="text-[#3aa4de] hover:text-mm-blue transition">Home</a>
            <a href="/quem-somos" class="text-[#3aa4de] hover:text-mm-blue transition">Quem Somos</a>
            <a href="/produtos" class="text-[#3aa4de] hover:text-mm-blue transition">Produtos</a>
            <a href="/galeria" class="text-[#3aa4de] hover:text-mm-blue transition">Galeria</a>
            <a href="/blog" class="text-[#3aa4de] hover:text-mm-blue transition">Blog</a>
            <a href="/contato" class="text-[#3aa4de] hover:text-mm-blue transition">Contato</a>
            
            <a href="/carrinho" class="relative text-mm-blue hover:text-mm-darkblue transition ml-4 text-xl flex items-center">
                <i class="fas fa-shopping-cart"></i>
                <span class="badge-carrinho absolute -top-2 -right-3 bg-mm-yellow text-gray-900 text-[10px] font-black w-4 h-4 flex items-center justify-center rounded-full hidden">0</span>
            </a>
        </nav>

        <div class="flex md:hidden items-center gap-5">
            <a href="/carrinho" class="relative text-mm-blue text-2xl flex items-center">
                <i class="fas fa-shopping-cart"></i>
                <span class="badge-carrinho absolute -top-2 -right-3 bg-mm-yellow text-gray-900 text-[10px] font-black w-4 h-4 flex items-center justify-center rounded-full hidden">0</span>
            </a>
            
            <button id="menu-toggle" class="text-mm-blue text-3xl focus:outline-none" aria-label="Abrir Menu">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </header>

    <div id="mobile-menu" class="fixed inset-0 bg-mm-darkblue z-[150] flex flex-col items-center justify-center gap-8 transition-all duration-300 translate-x-full opacity-0 pointer-events-none">
        <button id="menu-close" class="absolute top-8 right-8 text-white text-4xl">
            <i class="fas fa-times"></i>
        </button>
        
        <nav class="flex flex-col items-center gap-6">
            <a href="/" class="text-white text-2xl font-bold hover:text-mm-yellow transition">Home</a>
            <a href="/quem-somos" class="text-white text-2xl font-bold hover:text-mm-yellow transition">Quem Somos</a>
            <a href="/produtos" class="text-white text-2xl font-bold hover:text-mm-yellow transition">Produtos</a>
            <a href="/galeria" class="text-white text-2xl font-bold hover:text-mm-yellow transition">Galeria</a>
            <a href="/blog" class="text-white text-2xl font-bold hover:text-mm-yellow transition">Blog</a>
            <a href="/contato" class="text-white text-2xl font-bold hover:text-mm-yellow transition">Contato</a>
        </nav>
    </div>

    <main>
        <slot />
    </main>

    <footer class="w-full bg-[#1a1a1a] pt-16 pb-6 mt-12 text-white">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-sm mb-12">
                
                <div class="flex flex-col items-center md:items-start">
                    <a href="/" class="mb-6 transition hover:scale-105">
                        <img src="/midia/logo4.png" alt="MM Montagens" class="w-[180px] h-auto object-contain">
                    </a>
                    <p class="text-gray-400 leading-relaxed mb-6 text-center md:text-left pr-0 md:pr-4">
                        A MM Montagens é sinônimo de qualidade. Somos fabricantes de uma grande variedade de produtos.
                    </p>
                    
                    <div class="flex items-center gap-2 text-gray-500 text-xs font-medium relative z-[200]">
                        <a 
                            href="/politica-de-privacidade" 
                            class="hover:text-mm-cyan transition-colors cursor-pointer"
                        >
                            Política de Privacidade
                        </a>             <span class="select-none">|</span>
                        <a href="/termos-de-uso" class="hover:text-mm-cyan transition-colors cursor-pointer">Termos de Uso</a>
                    </div>
                </div>

                <div class="flex flex-col items-center">
                    <h4 class="font-bold uppercase tracking-wide mb-6">SOLICITE O SEU ORÇAMENTO</h4>
                    <a href="/contato" class="inline-block bg-mm-blue hover:bg-[#0e6ba0] transition text-white font-bold py-3 px-12 rounded shadow-md uppercase">
                        Entre em contato
                    </a>
                </div>

                <div class="flex flex-col items-center md:items-start">
                    <h4 class="font-bold uppercase tracking-wide mb-6">ENTRE EM CONTATO</h4>
                    <ul class="text-gray-400 space-y-4 mb-8">
                        <li class="flex items-center gap-4">
                            <i class="fab fa-whatsapp text-mm-blue text-xl w-6"></i>
                            <span>(11) 99803-8196</span>
                        </li>
                        <li class="flex items-center gap-4">
                            <i class="fas fa-at text-mm-blue text-xl w-6"></i>
                            <span>mm.montagens@uol.com.br</span>
                        </li>
                        <li class="flex items-start gap-4">
                            <i class="fas fa-map-marker-alt text-mm-blue text-xl w-6"></i>
                            <span class="leading-relaxed">R. Marcello Müller, 766<br>Vila Independência, São Paulo - SP,<br>03223-060</span>
                        </li>
                    </ul>

                    <div class="flex gap-4">
                        <a href="https://www.facebook.com/mmontagens2005" target="_blank" class="w-10 h-10 rounded-full bg-mm-blue text-white flex items-center justify-center hover:bg-white hover:text-mm-blue transition shadow-md">
                            <i class="fab fa-facebook-f text-lg"></i>
                        </a>
                        <a href="https://www.instagram.com/mm___montagens/" target="_blank" class="w-10 h-10 rounded-full bg-mm-blue text-white flex items-center justify-center hover:bg-white hover:text-mm-blue transition shadow-md">
                            <i class="fab fa-instagram text-lg"></i>
                        </a>
                        <a href="https://www.linkedin.com/company/mm-montagens/" target="_blank" class="w-10 h-10 rounded-full bg-mm-blue text-white flex items-center justify-center hover:bg-white hover:text-mm-blue transition shadow-md">
                            <i class="fab fa-linkedin-in text-lg"></i>
                        </a>
                    </div>
                </div>

            </div>

            <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] text-gray-500 font-medium uppercase tracking-widest">
                <p>© 2026 MM Montagens - Todos os direitos reservados.</p>
                <a href="https://www.linkedin.com/in/matheus-dos-santos26/" target="_blank" class="hover:text-white transition-colors flex items-center gap-2">
                    Desenvolvido por <span class="text-mm-cyan font-bold">Matheus</span>
                </a>
            </div>
        </div>
    </footer>

    <a href="/carrinho" id="btn-carrinho-flutuante" class="fixed bottom-10 right-6 bg-mm-blue text-white w-16 h-16 rounded-full items-center justify-center text-2xl shadow-2xl hover:scale-110 transition-transform duration-300 z-50 hidden border-2 border-white">
        <i class="fas fa-shopping-cart relative">
            <span class="badge-carrinho absolute -top-2 -right-3 bg-mm-yellow text-gray-900 text-[10px] font-black w-5 h-5 flex items-center justify-center rounded-full hidden">0</span>
        </i>
    </a>

    <script is:inline>
        const menuToggle = document.getElementById('menu-toggle');
        const menuClose = document.getElementById('menu-close');
        const mobileMenu = document.getElementById('mobile-menu');

        function toggleMenu() {
            const isOpen = mobileMenu.classList.contains('translate-x-0');
            if (isOpen) {
                mobileMenu.classList.remove('translate-x-0', 'opacity-100', 'pointer-events-auto');
                mobileMenu.classList.add('translate-x-full', 'opacity-0', 'pointer-events-none');
            } else {
                mobileMenu.classList.remove('translate-x-full', 'opacity-0', 'pointer-events-none');
                mobileMenu.classList.add('translate-x-0', 'opacity-100', 'pointer-events-auto');
            }
        }

        menuToggle?.addEventListener('click', toggleMenu);
        menuClose?.addEventListener('click', toggleMenu);

        const navLinks = mobileMenu?.querySelectorAll('a');
        navLinks?.forEach(link => link.addEventListener('click', toggleMenu));
    </script>
    
    <script src="/carrinho.js" is:inline></script>
</body>
</html>