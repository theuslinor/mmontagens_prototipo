---
import LayoutBase from '../layouts/LayoutBase.astro';
---

<LayoutBase title="MM Montagens - Categorias">
    <section class="relative w-full h-[280px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1489c8]/95 via-[#1489c8]/85 to-[#0e6ba0]/95 mix-blend-multiply"></div>
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[75px] md:text-[90px] font-condensed font-bold leading-none tracking-tight drop-shadow-md uppercase">NOSSAS CATEGORIAS</h1>
        </div>
    </section>

    <section class="w-full py-20 bg-gray-50 min-h-[500px]">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                
                <a href="/produtos/categoria-ganchos" class="relative w-full h-[300px] bg-white rounded-lg overflow-hidden group cursor-pointer shadow-md hover:shadow-2xl transition-all duration-300">
                    <img 
                        src="/midia/gancho/canaletado/gancho-canaletado-30cm-zincado.jpeg" 
                        alt="Ganchos" 
                        class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                        onerror="this.src='/midia/logo4.png'"
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <div class="absolute bottom-6 left-6 right-6">
                        <h3 class="text-white font-bold text-[24px] leading-tight mb-2">Ganchos</h3>
                        <span class="text-mm-yellow text-sm font-semibold flex items-center gap-2">Ver produtos <i class="fas fa-arrow-right text-xs"></i></span>
                    </div>
                </a>

                <a href="/produtos/categoria-barras" class="relative w-full h-[300px] bg-white rounded-lg overflow-hidden group cursor-pointer shadow-md hover:shadow-2xl transition-all duration-300">
    
                    <div class="absolute inset-0 flex items-center justify-center p-0">
                        <img 
                            src="/midia/barra-expositora/barra-gondola-preta.png" 
                            alt="Barras Expositoras" 
                            class="max-w-full max-h-[60%] object-contain group-hover:scale-110 transition duration-700"
                            onerror="this.src='/midia/logo4.png'"
                        >
                    </div>

                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    
                    <div class="absolute bottom-6 left-6 right-6">
                        <h3 class="text-white font-bold text-[24px] leading-tight mb-2">Barras Expositoras</h3>
                        <span class="text-mm-yellow text-sm font-semibold flex items-center gap-2">Ver produtos <i class="fas fa-arrow-right text-xs"></i></span>
                    </div>
                </a>

                <a href="/produtos/categoria-gondolas" class="relative w-full h-[300px] bg-white rounded-lg overflow-hidden group cursor-pointer shadow-md hover:shadow-2xl transition-all duration-300">
                    <img 
                        src="https://images.unsplash.com/photo-1578916171728-46686eac8d58?auto=format&fit=crop&q=80" 
                        alt="Gôndolas" 
                        class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <div class="absolute bottom-6 left-6 right-6">
                        <h3 class="text-white font-bold text-[24px] leading-tight mb-2">Gôndolas</h3>
                        <span class="text-mm-yellow text-sm font-semibold flex items-center gap-2">Ver produtos <i class="fas fa-arrow-right text-xs"></i></span>
                    </div>
                </a>

                <a href="/produtos/categoria-suportes" class="relative w-full h-[300px] bg-white rounded-lg overflow-hidden group cursor-pointer shadow-md hover:shadow-2xl transition-all duration-300">
                    <img 
                        src="/midia/suportes/suporte-faca.jpeg" 
                        alt="Suportes" 
                        class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                        onerror="this.src='/midia/logo4.png'"
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <div class="absolute bottom-6 left-6 right-6">
                        <h3 class="text-white font-bold text-[24px] leading-tight mb-2">Suportes</h3>
                        <span class="text-mm-yellow text-sm font-semibold flex items-center gap-2">Ver produtos <i class="fas fa-arrow-right text-xs"></i></span>
                    </div>
                </a>

            </div>
        </div>
    </section>
</LayoutBase>