---
// src/pages/galeria/[slug].astro
import LayoutBase from '../../layouts/LayoutBase.astro';
import { galeriaCategorias } from '../../data/galeria.js';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  return galeriaCategorias.map(cat => ({
    params: { slug: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;

// --- LÓGICA MÁGICA: LER MÚLTIPLAS PASTAS ---
let fotos = [];

// Transformamos o folder em array caso ele seja apenas uma string (garante compatibilidade)
const pastasParaLer = Array.isArray(cat.folder) ? cat.folder : [cat.folder];

pastasParaLer.forEach(pasta => {
    const diretórioDaMidia = path.join(process.cwd(), 'public', 'midia', pasta);
    
    try {
        if (fs.existsSync(diretórioDaMidia)) {
            const arquivos = fs.readdirSync(diretórioDaMidia);
            const fotosDaPasta = arquivos
                .filter(file => /\.(jpg|jpeg|png|webp|avif|gif|svg)$/i.test(file))
                .map(file => `/midia/${pasta}/${file}`);
            
            // Junta as fotos desta pasta com as fotos já encontradas
            fotos = [...fotos, ...fotosDaPasta];
        }
    } catch (error) {
        console.error(`Erro ao ler a pasta ${pasta}:`, error);
    }
});

// Opcional: Embaralhar as fotos para não ficarem separadas por pasta no grid
// fotos = fotos.sort(() => Math.random() - 0.5);
---

<LayoutBase title={`${cat.nome} - Galeria MM Montagens`}>
    <section class="w-full pt-12 pb-20 bg-gray-50 min-h-screen">
        <div class="container mx-auto px-6 lg:px-24">
            
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
                <div>
                    <button onclick="history.back()" class="text-gray-400 hover:text-mm-blue font-bold text-xs uppercase tracking-widest flex items-center gap-2 mb-4 transition-all">
                        <i class="fas fa-arrow-left"></i> Voltar para Galeria
                    </button>
                    <h1 class="text-4xl font-black text-gray-900 uppercase tracking-tighter">{cat.nome}</h1>
                    <p class="text-gray-500 font-medium italic italic">Mostrando {fotos.length} itens de diversas categorias</p>
                </div>

                <a href={cat.linkCatalogo} class="bg-mm-blue hover:bg-mm-darkblue text-white px-8 py-4 rounded-xl font-black uppercase tracking-wide shadow-lg transition-all flex items-center gap-3 w-fit">
                    <i class="fas fa-shopping-cart"></i>
                    Ver Catálogo Completo
                </a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                {fotos.map((foto, index) => (
                    <div 
                        class="relative aspect-square bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl cursor-zoom-in group transition-all"
                        onclick={`window.openLightbox('${foto}')`}
                    >
                        <img 
                            src={foto} 
                            alt={`Foto ${index + 1}`} 
                            class="w-full h-full object-cover transition duration-500 group-hover:scale-110"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-mm-darkblue/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-mm-blue shadow-xl">
                                <i class="fas fa-search-plus"></i>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            {fotos.length === 0 && (
                <div class="text-center py-20">
                    <p class="text-gray-400 font-bold uppercase italic">Nenhuma foto encontrada nas pastas selecionadas.</p>
                </div>
            )}
        </div>
    </section>

    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden items-center justify-center p-4" onclick="window.closeLightbox()">
        <button class="absolute top-6 right-6 text-white text-4xl"><i class="fas fa-times"></i></button>
        <img id="lightbox-img" src="" class="max-w-full max-h-full rounded-lg shadow-2xl object-contain" />
    </div>

</LayoutBase>

<script is:inline>
    // Mesmas funções de abrir e fechar que já funcionam
    window.openLightbox = function(src) {
        const lightbox = document.getElementById('lightbox');
        const img = document.getElementById('lightbox-img');
        img.src = src;
        lightbox.classList.replace('hidden', 'flex');
        document.body.style.overflow = 'hidden';
    };
    window.closeLightbox = function() {
        const lightbox = document.getElementById('lightbox');
        lightbox.classList.replace('flex', 'hidden');
        document.body.style.overflow = 'auto';
    };
</script>