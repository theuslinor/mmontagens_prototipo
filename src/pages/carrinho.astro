---
// src/pages/carrinho.astro
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Orçamento - MM Montagens</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { mm: { blue: '#1489c8', darkblue: '#0d5d9c', yellow: '#fbc02d' } }
                }
            }
        }
    </script>
    <style>
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        input[type=number] { -moz-appearance: textfield; }
    </style>
</head>
<body class="font-sans antialiased text-gray-800 bg-[#f4f7f6]">

    <header class="w-full bg-white h-[90px] flex items-center justify-between px-8 lg:px-24 shadow-sm relative z-50 border-b border-gray-100">
        <a href="/" class="flex items-center justify-center transition hover:scale-105">
            <img src="/midia/logo4.png" alt="MM Montagens" class="w-[140px] h-auto object-contain">    
        </a>
        <a href="/produtos" class="text-mm-blue hover:text-mm-darkblue font-bold flex items-center gap-2 transition bg-blue-50 px-4 py-2 rounded-full text-sm shadow-sm hover:shadow">
            <i class="fas fa-arrow-left"></i> Continuar Comprando
        </a>
    </header>

    <section class="container mx-auto px-4 lg:px-24 py-12 min-h-[600px]">
        
        <div class="flex items-center gap-3 mb-8 border-b border-gray-200 pb-4">
            <i class="fas fa-shopping-cart text-3xl text-mm-blue"></i>
            <h1 class="text-3xl font-black text-gray-800 tracking-tight">Meu Orçamento</h1>
        </div>

        <div class="flex flex-col lg:flex-row gap-8 items-start hidden" id="carrinho-conteudo">
            
            <div class="w-full lg:w-2/3 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="hidden md:grid grid-cols-[1fr_120px_120px_60px] gap-4 p-4 bg-gray-50 border-b border-gray-200 text-xs font-bold text-gray-500 uppercase tracking-wider">
                    <div>Produto</div>
                    <div class="text-center">Quantidade</div>
                    <div class="text-right">Subtotal</div>
                    <div class="text-center">Ação</div>
                </div>

                <div id="lista-carrinho" class="flex flex-col"></div>
                
                <div class="p-4 bg-gray-50 border-t border-gray-200 flex justify-between items-center">
                    <button onclick="limparCarrinho()" class="text-red-500 hover:text-red-700 text-sm font-bold flex items-center gap-2 transition">
                        <i class="fas fa-trash"></i> Esvaziar Orçamento
                    </button>
                </div>
            </div>

            <div class="w-full lg:w-1/3 bg-white rounded-xl shadow-sm border border-gray-200 p-6 sticky top-8">
                <h2 class="text-xl font-bold text-gray-800 mb-6 pb-4 border-b border-gray-100">Resumo do Pedido</h2>
                
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between items-center text-gray-600">
                        <span>Total de Produtos:</span>
                        <span id="resumo-total-produtos" class="font-bold text-lg text-gray-800">0</span>
                    </div>
                    
                    <div class="flex justify-between items-center text-gray-600 border-b border-gray-50 pb-4">
                        <span>Total de Peças:</span>
                        <span id="resumo-total-pecas" class="font-bold text-lg text-gray-800">0</span>
                    </div>

                    <div class="pt-2 flex flex-col gap-1">
                        <span class="text-[10px] font-black text-gray-400 uppercase">Valor Total Estimado</span>
                        <div class="flex items-baseline gap-1">
                            <span class="text-mm-blue font-bold text-xl">R$</span>
                            <span id="total-geral-carrinho" class="text-4xl font-black text-mm-blue leading-none">0,00</span>
                        </div>
                        <div id="aviso-orcamento" class="hidden">
                            <span class="text-[10px] text-orange-500 font-bold uppercase mt-1">+ itens sob consulta</span>
                        </div>
                    </div>
                </div>

                <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 mb-8">
                    <p class="text-[11px] text-mm-darkblue leading-relaxed text-center">
                        <i class="fas fa-info-circle mb-1 text-lg"></i><br>
                        Nossos consultores analisarão seu pedido e enviarão uma proposta comercial final com frete e condições.
                    </p>
                </div>

                <button onclick="enviarParaWhatsApp()" class="w-full bg-[#25D366] hover:bg-[#20ba5a] text-white font-black text-lg py-5 rounded-xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 flex justify-center items-center gap-3">
                    <i class="fab fa-whatsapp text-2xl"></i> ENVIAR ORÇAMENTO
                </button>
            </div>
        </div>

        <div id="carrinho-vazio" class="bg-white rounded-xl shadow-sm border border-gray-200 p-16 text-center hidden">
            <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                <i class="fas fa-shopping-basket text-4xl"></i>
            </div>
            <h2 class="text-2xl font-black text-gray-800 mb-2">Seu orçamento está vazio!</h2>
            <p class="text-gray-500 mb-8">Navegue pelas nossas categorias e adicione produtos para solicitar um preço.</p>
            <a href="/produtos" class="inline-block bg-mm-blue hover:bg-mm-darkblue text-white font-bold px-10 py-4 rounded-full transition shadow-md">
                VER PRODUTOS
            </a>
        </div>

    </section>

    <script is:inline>
        const CHAVE = "mm_montagens_carrinho";

        function getCarrinho() {
            return JSON.parse(localStorage.getItem(CHAVE)) || [];
        }

        function salvarCarrinho(itens) {
            localStorage.setItem(CHAVE, JSON.stringify(itens));
        }

        function renderizarPaginaCarrinho() {
            const itens = getCarrinho();
            const container = document.getElementById('lista-carrinho');
            const areaConteudo = document.getElementById('carrinho-conteudo');
            const areaVazia = document.getElementById('carrinho-vazio');
            
            const resumoProdutos = document.getElementById('resumo-total-produtos');
            const resumoPecas = document.getElementById('resumo-total-pecas');
            const displayTotalGeral = document.getElementById('total-geral-carrinho');
            const avisoOrcamento = document.getElementById('aviso-orcamento');

            if (itens.length === 0) {
                areaConteudo.classList.add('hidden');
                areaVazia.classList.remove('hidden');
                return;
            }

            areaConteudo.classList.remove('hidden');
            areaVazia.classList.add('hidden');
            container.innerHTML = ''; 

            let totalPecas = 0;
            let valorTotalCompra = 0;
            let temSobConsulta = false;

            itens.forEach((item, index) => {
                const quantidade = parseInt(item.qty) || 0;
                const precoUnitario = parseFloat(item.preco) || 0;
                const subtotalItem = quantidade * precoUnitario;
                
                totalPecas += quantidade;
                
                let unitarioHTML, subtotalHTML, corTexto;

                if (precoUnitario <= 0) {
                    unitarioHTML = "Sob Consulta";
                    subtotalHTML = "A Combinar";
                    corTexto = "text-orange-500";
                    temSobConsulta = true;
                } else {
                    unitarioHTML = `R$ ${precoUnitario.toFixed(2).replace('.', ',')}`;
                    subtotalHTML = `R$ ${subtotalItem.toFixed(2).replace('.', ',')}`;
                    corTexto = "text-mm-blue";
                    valorTotalCompra += subtotalItem;
                }
                
                container.innerHTML += `
                    <div class="grid grid-cols-1 md:grid-cols-[1fr_120px_120px_60px] gap-4 p-4 md:p-6 border-b border-gray-100 items-center hover:bg-gray-50 transition">
                        <div class="flex items-center gap-4">
                            <div class="w-20 h-20 bg-white border border-gray-200 rounded p-1 flex-shrink-0 flex items-center justify-center">
                                <img src="${item.img}" onerror="this.src='/midia/logo4.png'" alt="${item.nome}" class="max-h-full object-contain mix-blend-multiply">
                            </div>
                            <div class="flex flex-col">
                                <h3 class="font-bold text-gray-800 text-sm leading-tight">${item.nome}</h3>
                                <span class="text-[10px] text-gray-400 uppercase font-black mt-1 tracking-wider">${item.variacao || 'Padrão'}</span>
                                <span class="text-[11px] ${corTexto} font-bold mt-1">UN: ${unitarioHTML}</span>
                            </div>
                        </div>

                        <div class="flex items-center justify-center">
                            <div class="flex border border-gray-300 rounded-lg overflow-hidden bg-white shadow-sm">
                                <button onclick="alterarQtd(${index}, -1)" class="w-9 h-10 text-gray-500 hover:bg-gray-100 flex items-center justify-center border-r border-gray-300">
                                    <i class="fas fa-minus text-[10px]"></i>
                                </button>
                                <input 
                                    type="number" 
                                    min="1" 
                                    value="${quantidade}" 
                                    onchange="window.atualizarInputManual(${index}, this.value)" 
                                    class="w-12 h-10 text-center font-bold text-gray-700 text-sm outline-none bg-transparent"
                                >
                                <button onclick="alterarQtd(${index}, 1)" class="w-9 h-10 text-gray-500 hover:bg-gray-100 flex items-center justify-center border-l border-gray-300">
                                    <i class="fas fa-plus text-[10px]"></i>
                                </button>
                            </div>
                        </div>

                        <div class="text-right font-black ${precoUnitario <= 0 ? 'text-orange-500' : 'text-gray-900'} text-sm">
                            ${subtotalHTML}
                        </div>

                        <div class="flex justify-center">
                            <button onclick="removerItem(${index})" class="text-gray-300 hover:text-red-500 transition-colors p-2">
                                <i class="fas fa-trash-alt text-lg"></i>
                            </button>
                        </div>
                    </div>
                `;
            });

            resumoProdutos.innerText = itens.length;
            resumoPecas.innerText = totalPecas;
            displayTotalGeral.innerText = valorTotalCompra.toLocaleString('pt-BR', { minimumFractionDigits: 2 });
            
            if (temSobConsulta) avisoOrcamento.classList.remove('hidden');
            else avisoOrcamento.classList.add('hidden');
        }

        window.alterarQtd = function(index, valor) {
            let itens = getCarrinho();
            let novaQtd = (parseInt(itens[index].qty) || 1) + valor;
            if (novaQtd >= 1) {
                itens[index].qty = novaQtd;
                salvarCarrinho(itens);
                renderizarPaginaCarrinho();
            }
        };

        window.atualizarInputManual = function(index, valor) {
            let itens = getCarrinho();
            let novaQtd = parseInt(valor);
            if (isNaN(novaQtd) || novaQtd < 1) novaQtd = 1;
            itens[index].qty = novaQtd;
            salvarCarrinho(itens);
            renderizarPaginaCarrinho();
        };

        window.removerItem = function(index) {
            let itens = getCarrinho();
            itens.splice(index, 1);
            salvarCarrinho(itens);
            renderizarPaginaCarrinho();
        };

        window.limparCarrinho = function() {
            if(confirm("Deseja esvaziar seu orçamento?")) {
                localStorage.removeItem(CHAVE);
                renderizarPaginaCarrinho();
            }
        };

        window.enviarParaWhatsApp = function() {
            const itens = getCarrinho();
            if (itens.length === 0) return;

            let texto = "Olá, MM Montagens! Gostaria de solicitar um orçamento:%0A%0A";
            let totalSoma = 0;
            let temOrcamento = false;
            
            itens.forEach(i => { 
                const preco = parseFloat(i.preco) || 0;
                const subtotal = i.qty * preco;
                let uStr, sStr;

                if (preco <= 0) {
                    uStr = "A COMBINAR";
                    sStr = "A COMBINAR";
                    temOrcamento = true;
                } else {
                    uStr = `R$ ${preco.toFixed(2).replace('.', ',')}`;
                    sStr = `R$ ${subtotal.toFixed(2).replace('.', ',')}`;
                    totalSoma += subtotal;
                }

                texto += `*${i.qty}x ${i.nome}*%0A`;
                texto += ` Opção: ${i.variacao}%0A`;
                texto += ` UN: ${uStr} | *SUBTOTAL: ${sStr}*%0A%0A`;
            });
            
            texto += `---------------------------------%0A`;
            const totalFinalStr = totalSoma > 0 ? `R$ ${totalSoma.toFixed(2).replace('.', ',')}` : "A COMBINAR";
            texto += `*VALOR TOTAL ESTIMADO: ${totalFinalStr}*${(totalSoma > 0 && temOrcamento) ? ' (Mais itens a combinar)' : ''}%0A%0A`;
            texto += "Aguardamos o retorno com as condições de frete e faturamento.";
            
            window.open(`https://wa.me/5511998038196?text=${texto}`, "_blank");
        }

        window.addEventListener('DOMContentLoaded', renderizarPaginaCarrinho);
    </script>
</body>
</html>