---
import LayoutBase from '../layouts/LayoutBase.astro';
import { galeriaCategorias } from '../data/galeria.js';
---

<LayoutBase title="MM Montagens - Galeria">
    <section class="relative w-full h-[280px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1489c8]/95 via-[#1489c8]/85 to-[#0e6ba0]/95 mix-blend-multiply"></div>
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[75px] md:text-[90px] font-black leading-none tracking-tight drop-shadow-md">GALERIA</h1>
        </div>
    </section>

    <section class="w-full py-20 bg-white min-h-[500px]">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                
                {galeriaCategorias.map(cat => (
                    <a href={`/galeria/${cat.slug}`} class="relative w-full h-[260px] bg-gray-100 rounded-2xl overflow-hidden group cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500">
                        <img src={cat.capa} alt={cat.nome} class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                        <div class="absolute bottom-5 left-5 right-5">
                            <h3 class="text-white font-black text-[22px] leading-tight drop-shadow-md uppercase">{cat.nome}</h3>
                            <span class="text-mm-yellow text-xs font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Ver Álbum <i class="fas fa-arrow-right ml-1"></i></span>
                        </div>
                    </a>
                ))}

            </div>
        </div>
    </section>
</LayoutBase>