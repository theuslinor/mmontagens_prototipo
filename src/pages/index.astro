---
import LayoutBase from '../layouts/LayoutBase.astro';
import ClientesCarousel from '../components/ClientesCarousel.astro';
import CategoriasDestaque from '../components/CategoriasDestaque.astro';
import fs from 'node:fs';
import path from 'node:path';

// 1. Lógica do Slideshow do Topo (Mantida)
const fotosDir = path.join(process.cwd(), 'public/midia/fotos-destaques');
let fotosLista = [];

try {
    if (fs.existsSync(fotosDir)) {
        fotosLista = fs.readdirSync(fotosDir)
            .filter(file => /\.(png|jpe?g|webp|avif|svg)$/i.test(file))
            .map(file => `/midia/fotos-destaques/${file}`);
    }
} catch (e) {
    console.error("Erro ao ler a pasta de fotos:", e);
}

if (fotosLista.length === 0) {
    fotosLista = ["/midia/gancho/canaletado/gancho-canaletado-preto-fundo-branco.png"];
}

// 2. DADOS REAIS DO SEU BLOG
const ultimasNoticias = [
    {
        titulo: "Cinco formas de manter a sua loja organizada",
        resumo: "Organizar a loja não é apenas estética; é estratégia. Uma boa organização facilita a experiência de compra e otimiza o giro de estoque.",
        data: "15 Mar, 2023",
        img: "/midia/blog/abcasa.jpg",
        slug: "loja-organizada"
    },
    {
        titulo: "5 Dicas para montar uma loja que se destaque",
        resumo: "Existem sugestões que valem para qualquer loja e ramo. Levantamos as 5 principais para ajudar você a transformar seu ponto de venda.",
        data: "25 Jan, 2023",
        img: "/midia/blog/montar_loja.jpg",
        slug: "dicas-montar-loja"
    },
    {
        titulo: "Qual o tipo de suporte ideal para a sua loja?",
        resumo: "A exposição correta gera valor. Entenda como os ganchos para painéis canaletados se adequam ao seu tipo de comércio.",
        data: "01 Fev, 2023",
        img: "/midia/blog/tipo_ideal.png",
        slug: "suporte-ideal"
    }
];
---

<LayoutBase title="MM Montagens - Home">

    <style>
        #hero-img-1, #hero-img-2 {
            transition: opacity 0.8s ease-in-out, transform 0.8s ease-in-out;
        }
    </style>

    <section class="relative w-full h-[500px] bg-[#1c1d1e] flex items-center overflow-hidden border-t-2 border-mm-blue">
        <div class="absolute -top-[250px] -left-[150px] w-[500px] h-[500px] bg-mm-blue rounded-full opacity-90 blur-[2px]"></div>
        <div class="absolute top-[-50%] -right-[15%] w-[1200px] h-[1200px] bg-[#f5f5f5] rounded-full z-0 shadow-2xl"></div>
        <div class="absolute top-[-40%] -right-[20%] w-[1200px] h-[1200px] bg-gradient-to-br from-[#0e60a1] to-mm-blue rounded-full z-0 shadow-inner"></div>

        <div class="container mx-auto px-8 lg:px-24 relative z-10 flex justify-between items-center w-full">
            <div class="max-w-xl">
                <h1 class="flex flex-col gap-0">
                    <span class="text-white font-bold text-[55px] leading-tight tracking-wide uppercase">Soluções</span>
                    <span class="text-[#EDC241] font-light text-[45px] leading-none tracking-widest -mt-2 uppercase">Personalizadas</span>
                    <span class="text-white font-bold text-[42px] leading-tight tracking-wide mt-2 uppercase">Para o seu negócio</span>
                </h1>
                <a href="/quem-somos" class="inline-block mt-8 px-6 py-2 rounded border border-white text-white font-light text-lg hover:bg-white hover:text-mm-dark transition">
                    Saiba mais
                </a>
            </div>

            <div class="relative w-[450px] h-[400px] hidden lg:block mr-8">
                <div class="absolute top-0 right-0 w-[300px] h-[300px] rounded-full border-[8px] border-[#e8e9eb] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.5)] z-10 bg-white">
                    <img id="hero-img-1" src={fotosLista[0]} alt="MM Montagens" class="w-full h-full object-cover">
                </div>
                
                <div class="absolute bottom-4 left-0 w-[220px] h-[220px] rounded-full border-[8px] border-[#e8e9eb] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.5)] z-20 bg-white">
                    <img id="hero-img-2" src={fotosLista[1] || fotosLista[0]} alt="MM Montagens" class="w-full h-full object-cover">
                </div>
            </div>
        </div>
    </section>

    <div id="slideshow-data" data-photos={JSON.stringify(fotosLista)}></div>

    <CategoriasDestaque />

    <section class="w-full pt-20 pb-20 bg-white relative">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="text-center mb-16">
                <h3 class="text-mm-blue text-xs font-bold uppercase tracking-[0.3em] mb-3">CONHECIMENTO ESPECIALIZADO</h3>
                <h2 class="text-gray-900 text-4xl font-black uppercase tracking-tighter">Últimas do Blog</h2>
                <div class="w-20 h-1.5 bg-mm-yellow mx-auto mt-6"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                {ultimasNoticias.map((post) => (
                    <a href={`/blog/${post.slug}`} class="group flex flex-col">
                        <div class="relative h-64 w-full overflow-hidden rounded-3xl mb-6 shadow-md border border-gray-100">
                            <img 
                                src={post.img} 
                                alt={post.titulo} 
                                class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-mm-darkblue/40 to-transparent"></div>
                            <span class="absolute bottom-4 left-6 bg-white text-mm-blue text-[10px] font-black px-3 py-1 rounded-full uppercase shadow-sm">
                                {post.data}
                            </span>
                        </div>
                        
                        <h4 class="text-xl font-black text-gray-900 leading-tight mb-4 group-hover:text-mm-blue transition-colors uppercase">
                            {post.titulo}
                        </h4>
                        
                        <p class="text-gray-500 text-sm leading-relaxed mb-6 line-clamp-3 font-medium">
                            {post.resumo}
                        </p>
                        
                        <div class="mt-auto flex items-center gap-2 text-mm-blue font-bold text-[11px] uppercase tracking-widest group-hover:gap-4 transition-all">
                            Ler matéria completa <i class="fas fa-arrow-right"></i>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <section class="w-full py-16 bg-mm-light relative">
        <ClientesCarousel />
    </section>

</LayoutBase>

<script>
    // Script do Slideshow (Mantido)
    const dataEl = document.getElementById('slideshow-data');
    const fotos = JSON.parse(dataEl.dataset.photos || '[]');
    const img1 = document.getElementById('hero-img-1') as HTMLImageElement;
    const img2 = document.getElementById('hero-img-2') as HTMLImageElement;

    if (fotos.length > 0 && img1 && img2) {
        const trocar = () => {
            img1.style.opacity = '0';
            img2.style.opacity = '0';
            img1.style.transform = 'scale(0.95)';
            setTimeout(() => {
                const idx1 = Math.floor(Math.random() * fotos.length);
                let idx2 = Math.floor(Math.random() * fotos.length);
                if (fotos.length > 1) while(idx2 === idx1) idx2 = Math.floor(Math.random() * fotos.length);
                img1.src = encodeURI(fotos[idx1]);
                img2.src = encodeURI(fotos[idx2]);
                img1.style.opacity = '1';
                img2.style.opacity = '1';
                img1.style.transform = 'scale(1)';
            }, 800);
        };
        setInterval(trocar, 4500);
    }
</script>