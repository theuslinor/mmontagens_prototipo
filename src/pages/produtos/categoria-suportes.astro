---
// src/pages/produtos/categoria-suportes.astro
import LayoutBase from '../../layouts/LayoutBase.astro';
import { categorias } from '../../data/produtos.js';

const categoria = categorias.find(cat => cat.id === 'suportes');
const produtos = categoria ? categoria.items : [];
---

<LayoutBase title="Suportes - MM Montagens">
    <section class="w-full pt-6 pb-12 bg-white min-h-screen">
        <div class="container mx-auto px-6 lg:px-24">
            
            <div class="mb-2">
                <button 
                    onclick="history.back()" 
                    class="inline-flex items-center gap-3 text-gray-400 hover:text-mm-blue font-bold transition-all group text-xs uppercase tracking-[0.2em]"
                >
                    <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center group-hover:bg-blue-50 transition-colors shadow-sm">
                        <i class="fas fa-arrow-left"></i>
                    </div>
                    Voltar para categorias
                </button>
            </div>

            <div class="flex items-center gap-4 mb-12 border-b border-gray-100 pb-6">
                <i class="fas fa-tools text-mm-blue text-2xl"></i>
                <h1 class="text-3xl font-black text-gray-900 uppercase tracking-tight">Nossos Suportes</h1>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
                {produtos.map(p => (
                    <a href={`/produtos/${p.slug}`} class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col overflow-hidden group block">
                        
                        <div class="aspect-square bg-gray-50 p-8 flex items-center justify-center overflow-hidden">
                            <img 
                                src={p.img} 
                                alt={p.nome} 
                                class="max-h-full object-contain mix-blend-multiply group-hover:scale-110 transition duration-500 rounded-xl"
                                onerror="this.src='/midia/logo4.png'"
                            />
                        </div>
                        
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-black text-gray-900 text-lg mb-1 leading-tight">{p.nome}</h3>
                            <p class="text-[10px] font-bold text-gray-400 uppercase mb-4 tracking-widest">
                                {p.variants && p.variants.length > 0 ? 'A partir de' : 'Projeto Especial'}
                            </p>
                            
                            <div class="mt-auto flex items-center justify-between">
                                <span class="text-2xl font-black text-mm-blue">
                                    {p.variants && p.variants[0] 
                                        ? `R$ ${p.variants[0].price.toFixed(2).replace('.', ',')}` 
                                        : 'Sob Consulta'}
                                </span>
                                
                                <div class="bg-mm-blue group-hover:bg-mm-darkblue text-white px-5 py-2.5 rounded-lg font-bold text-sm transition-all shadow-md">
                                    Ver Opções
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            {produtos.length === 0 && (
                <div class="text-center py-20 border-2 border-dashed border-gray-100 rounded-2xl">
                    <p class="text-gray-400 font-bold">Nenhum suporte cadastrado no banco de dados.</p>
                </div>
            )}
        </div>
    </section>
</LayoutBase>