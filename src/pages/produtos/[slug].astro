---
import LayoutBase from '../../layouts/LayoutBase.astro';
import { categorias } from '../../data/produtos.js';

export async function getStaticPaths() {
  const todosProdutos = categorias.flatMap(cat => cat.items);
  return todosProdutos.map(prod => ({
    params: { slug: prod.slug },
    props: { prod },
  }));
}

const { prod } = Astro.props;

// Pegamos as cores únicas para gerar os botões iniciais
const coresUnicas = [...new Set(prod.variants.map(v => v.cor))];
---

<LayoutBase title={`${prod.nome} - MM Montagens`}>
    <section class="w-full py-8 md:py-12 bg-white">
        <div class="container mx-auto px-6 lg:px-24">
            
            <div class="mb-8">
                <button 
                    onclick="history.back()" 
                    class="inline-flex items-center gap-2 text-gray-400 hover:text-mm-blue font-bold transition-all group text-sm uppercase tracking-widest"
                >
                    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center group-hover:bg-blue-50 transition-colors">
                        <i class="fas fa-arrow-left text-xs"></i>
                    </div>
                    Voltar
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                
                <div class="bg-gray-50 rounded-2xl p-8 flex items-center justify-center border border-gray-100 shadow-inner">
                    <img id="main-img" src={prod.variants[0].img} alt={prod.nome} class="max-h-[400px] object-contain mix-blend-multiply transition-all duration-300" />
                </div>

                <div class="flex flex-col">
                    <h1 class="text-3xl font-black text-gray-900 mb-6">{prod.nome}</h1>

                    <div class="mb-6">
                        <label class="block text-xs font-black text-gray-400 uppercase mb-3">Selecione a opção de COR:</label>
                        <div class="flex flex-wrap gap-2" id="color-options">
                            {coresUnicas.map((cor, index) => (
                                <button 
                                    class={`color-btn px-6 py-2 border-2 rounded-lg font-bold text-sm transition-all ${index === 0 ? 'border-mm-blue text-mm-blue bg-blue-50' : 'border-gray-200 text-gray-400'}`}
                                    onclick={`window.mudarCor('${cor}', this)`}
                                >
                                    {cor}
                                </button>
                            ))}
                        </div>
                    </div>

                    <div class="mb-8">
                        <label class="block text-xs font-black text-gray-400 uppercase mb-3">Selecione a opção de TAMANHO:</label>
                        <div class="flex flex-wrap gap-2" id="size-options">
                             </div>
                    </div>

                    <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 mb-6 flex flex-col gap-4">
                        <div class="flex justify-between items-end">
                            <div>
                                <span class="block text-[10px] font-black text-gray-400 uppercase mb-1">Preço Unitário</span>
                                <span class="text-2xl font-bold text-gray-600">R$ <span id="display-price">0,00</span></span>
                            </div>
                            <div class="flex flex-col items-center gap-1">
                                <label class="text-[10px] font-black text-gray-400 uppercase">Qtd</label>
                                <input id="qty-input" type="number" min="1" value="1" oninput="window.atualizarTotal()" class="w-20 p-3 border-2 border-gray-200 rounded-lg text-center font-bold outline-none focus:border-mm-blue" />
                            </div>
                        </div>
                        
                        <div class="border-t border-gray-200 pt-4 flex justify-between items-center">
                            <span class="text-xs font-black text-gray-900 uppercase tracking-tighter">Subtotal</span>
                            <span class="text-4xl font-black text-mm-blue">R$ <span id="display-total">0,00</span></span>
                        </div>
                    </div>

                    <button 
                        id="btn-add-orcamento"
                        onclick="window.enviarCarrinhoFinal(event)" 
                        class="w-full bg-[#25D366] text-white font-black py-5 rounded-2xl shadow-lg transition-all duration-500 flex justify-center items-center gap-4 text-xl uppercase tracking-wider overflow-hidden relative"
                    >
                        <span id="btn-content" class="flex items-center gap-4">
                            <i class="fas fa-cart-plus text-2xl"></i> 
                            <span>Adicionar ao Orçamento</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </section>
</LayoutBase>

<script is:inline define:vars={{ variants: prod.variants, slug: prod.slug, nome: prod.nome, codigo: prod.codigo }}>
    // Inicialização do estado
    let corSelecionada = variants[0].cor;
    let tamanhoSelecionado = "";
    let precoAtual = variants[0].price; // Começa com o preço da primeira variante

    // Tenta carregar a melhor extensão de imagem disponível
    async function carregarImagemInteligente(caminhoBase) {
        const imgElement = document.getElementById('main-img');
        const extensoes = ['.png', '.jpg', '.jpeg', '.webp', '.PNG', '.JPG', '.JPEG'];
        const caminhoSemExtensao = caminhoBase.replace(/\.[^/.]+$/, "");

        for (let ext of extensoes) {
            const urlTeste = caminhoSemExtensao + ext;
            try {
                const response = await fetch(urlTeste, { method: 'HEAD' });
                if (response.ok) {
                    imgElement.src = urlTeste;
                    return;
                }
            } catch (e) {}
        }
        imgElement.src = caminhoBase;
    }

    // Atualiza os displays de preço e subtotal
    window.atualizarTotal = function() {
        const qtyElement = document.getElementById('qty-input');
        const qty = parseInt(qtyElement.value) || 1;
        
        const total = precoAtual * qty;
        
        const displayTotal = document.getElementById('display-total');
        if (displayTotal) {
            displayTotal.innerText = total.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
    };

    // Lógica de troca de cor
    window.mudarCor = function(cor, btn) {
        corSelecionada = cor;
        document.querySelectorAll('.color-btn').forEach(b => {
            b.classList.remove('border-mm-blue', 'text-mm-blue', 'bg-blue-50');
            b.classList.add('border-gray-200', 'text-gray-400');
        });
        btn.classList.add('border-mm-blue', 'text-mm-blue', 'bg-blue-50');

        const tamanhosDisponiveis = variants.filter(v => v.cor === cor);
        renderizarTamanhos(tamanhosDisponiveis);
    };

    // Lógica de troca de tamanho
    window.mudarTamanho = function(variante, btn) {
        tamanhoSelecionado = variante.tamanho;
        precoAtual = variante.price;
        
        document.querySelectorAll('.size-btn').forEach(b => {
            b.classList.remove('border-mm-blue', 'text-mm-blue', 'bg-blue-50');
            b.classList.add('border-gray-200', 'text-gray-400');
        });
        btn.classList.add('border-mm-blue', 'text-mm-blue', 'bg-blue-50');

        carregarImagemInteligente(variante.img);
        
        document.getElementById('display-price').innerText = precoAtual.toFixed(2).replace('.', ',');
        window.atualizarTotal();
    };

    // Renderiza botões de tamanho baseado na cor
    function renderizarTamanhos(lista) {
        const container = document.getElementById('size-options');
        container.innerHTML = '';

        lista.forEach((v, index) => {
            const btn = document.createElement('button');
            btn.innerText = v.tamanho;
            btn.className = `size-btn px-6 py-2 border-2 rounded-lg font-bold text-sm transition-all ${index === 0 ? 'border-mm-blue text-mm-blue bg-blue-50' : 'border-gray-200 text-gray-400'}`;
            
            btn.onclick = () => window.mudarTamanho(v, btn);
            container.appendChild(btn);

            if(index === 0) window.mudarTamanho(v, btn);
        });
    }

    // Adiciona ao carrinho com feedback visual
    // Criamos uma variável fora da função para controlar o tempo
let timeoutFeedback; 

window.enviarCarrinhoFinal = function(event) {
    const btn = event.currentTarget;
    const btnContent = document.getElementById('btn-content');
    
    // Texto e ícone originais fixos (pra não bugar se clicar rápido)
    const conteudoOriginal = `<i class="fas fa-cart-plus text-2xl"></i> <span>Adicionar ao Orçamento</span>`;

    const qty = parseInt(document.getElementById('qty-input').value) || 1;
    const img = document.getElementById('main-img').src;
    const variacaoFull = `${corSelecionada} - ${tamanhoSelecionado}`;

    if (window.adicionarComVariacaoInterna) {
        // Envia para o carrinho (isso pode acontecer quantas vezes ele clicar)
        window.adicionarComVariacaoInterna(slug, nome, codigo, img, qty, variacaoFull, precoAtual);
        
        // --- LÓGICA DO FEEDBACK VISUAL ---
        
        // Se já houver um timer rodando, a gente cancela ele pra começar um novo
        if (timeoutFeedback) clearTimeout(timeoutFeedback);

        // Forçamos o estado "Adicionado" (Azul)
        btn.style.backgroundColor = '#1489c8'; // Cor mm-blue fixa
        btnContent.innerHTML = '<i class="fas fa-check text-2xl"></i> <span>Adicionado!</span>';

        // Marcamos o tempo para voltar ao normal (Verde)
        timeoutFeedback = setTimeout(() => {
            btn.style.backgroundColor = '#25D366'; // Volta pro verde
            btnContent.innerHTML = conteudoOriginal;
            timeoutFeedback = null; // Limpa a trava
        }, 1500);

    } else {
        console.error("Erro: carrinho.js não carregado.");
    }
};

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        const primeiraCorBtn = document.querySelector('.color-btn');
        if(primeiraCorBtn) window.mudarCor(corSelecionada, primeiraCorBtn);
    });
</script>