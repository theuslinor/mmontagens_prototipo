---
import LayoutBase from '../../layouts/LayoutBase.astro';
import { categorias } from '../../data/produtos.js';

export async function getStaticPaths() {
  const todosProdutos = categorias.flatMap(cat => cat.items);
  return todosProdutos.map(prod => ({
    params: { slug: prod.slug },
    props: { prod },
  }));
}

const { prod } = Astro.props;

// LÓGICA DE DADOS
const temVariantes = prod.variants && prod.variants.length > 0;

// Se for projeto (Gôndolas/Estantes), usamos o slider. Se for produto comum, imagem única.
const slides = !temVariantes && prod.images ? prod.images : [prod.img];
const coresUnicas = temVariantes ? [...new Set(prod.variants.map(v => v.cor))] : [];
const precoInicial = temVariantes ? prod.variants[0].price : 0;
---

<LayoutBase title={`${prod.nome} - MM Montagens`}>
    <section class="w-full py-8 md:py-12 bg-white">
        <div class="container mx-auto px-6 lg:px-24">
            
            <div class="mb-8">
                <button onclick="history.back()" class="inline-flex items-center gap-2 text-gray-400 hover:text-mm-blue font-bold transition-all group text-sm uppercase tracking-widest">
                    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center group-hover:bg-blue-50">
                        <i class="fas fa-arrow-left text-xs"></i>
                    </div>
                    Voltar
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                
                <div class="relative bg-gray-50 rounded-[32px] p-4 md:p-8 border border-gray-100 shadow-inner group overflow-hidden h-[400px] md:h-[550px] flex items-center justify-center">
                    
                    {temVariantes ? (
                        <img 
                            id="main-img" 
                            src={prod.variants[0].img} 
                            alt={prod.nome} 
                            class="max-h-full object-contain mix-blend-multiply transition-all duration-300"
                            onerror="this.src='/midia/logo4.png'"
                        />
                    ) : (
                        <div id="slider-container" class="relative w-full h-full flex items-center justify-center">
                            {slides.map((img, index) => (
                                <img 
                                    src={img} 
                                    alt={`${prod.nome} - ${index}`}
                                    class={`absolute max-h-full object-contain mix-blend-multiply transition-all duration-1000 ease-in-out transform ${index === 0 ? 'opacity-100 scale-100 z-10' : 'opacity-0 scale-95 z-0'}`}
                                    data-index={index}
                                />
                            ))}

                            {slides.length > 1 && (
                                <>
                                    <button id="prev-slide" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 shadow-md z-20 flex items-center justify-center text-mm-darkblue hover:bg-mm-blue hover:text-white transition-all">
                                        <i class="fas fa-chevron-left"></i>
                                    </button>
                                    <button id="next-slide" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 shadow-md z-20 flex items-center justify-center text-mm-darkblue hover:bg-mm-blue hover:text-white transition-all">
                                        <i class="fas fa-chevron-right"></i>
                                    </button>
                                    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-20">
                                        {slides.map((_, i) => (
                                            <div class={`slider-dot h-1.5 rounded-full transition-all duration-500 ${i === 0 ? 'bg-mm-blue w-8' : 'bg-gray-300 w-3'}`} data-index={i}></div>
                                        ))}
                                    </div>
                                </>
                            )}
                        </div>
                    )}
                </div>

                <div class="flex flex-col">
                    <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-2 uppercase tracking-tight">{prod.nome}</h1>
                    <p class="text-sm text-gray-400 mb-8 italic">Código: {prod.codigo}</p>

                    {temVariantes ? (
                        <div class="space-y-6">
                            <div>
                                <label class="block text-[10px] font-black text-gray-400 uppercase mb-3 tracking-widest">Selecione a Cor:</label>
                                <div class="flex flex-wrap gap-2">
                                    {coresUnicas.map((cor) => (
                                        <button 
                                            class="color-btn px-6 py-2 border-2 rounded-xl font-bold text-sm transition-all border-gray-200 text-gray-400 bg-white"
                                            onclick={`window.mudarCor('${cor}', this)`}
                                        >
                                            {cor}
                                        </button>
                                    ))}
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-gray-400 uppercase mb-3 tracking-widest">Tamanho Disponível:</label>
                                <div class="flex flex-wrap gap-2" id="size-options"></div>
                            </div>
                        </div>
                    ) : (
                        <div class="bg-blue-50 p-8 rounded-3xl border border-blue-100 border-l-8 border-l-mm-blue">
                            <h4 class="text-mm-blue font-black uppercase text-sm mb-2 italic">Projeto Personalizado</h4>
                            <p class="text-gray-600 text-sm leading-relaxed font-medium">
                                Gôndolas e Estantes são fabricadas sob medida. Entre em contato para receber um layout exclusivo para sua loja.
                            </p>
                        </div>
                    )}

                    <div class="bg-gray-50 p-6 rounded-3xl border border-gray-100 my-8 flex flex-col gap-6">
                        <div class="flex justify-between items-end">
                            <div>
                                <span class="block text-[10px] font-black text-gray-400 uppercase mb-1">Preço Unitário</span>
                                <span class="text-3xl font-black text-gray-700">
                                    {temVariantes ? (<>R$ <span id="display-price">{precoInicial.toFixed(2).replace('.', ',')}</span></>) : "A Combinar"}
                                </span>
                            </div>
                            <div class="text-center">
                                <label class="block text-[10px] font-black text-gray-400 uppercase mb-1">Qtd:</label>
                                <input id="qty-input" type="number" min="1" value="1" oninput="window.atualizarTotal()" class="w-16 p-3 border-2 border-gray-200 rounded-xl text-center font-bold outline-none focus:border-mm-blue" />
                            </div>
                        </div>
                        <div class="border-t border-gray-200 pt-6 flex justify-between items-center">
                            <span class="text-xs font-black text-gray-900 uppercase">Subtotal</span>
                            <span class="text-4xl font-black text-mm-blue">
                                {temVariantes ? (<>R$ <span id="display-total">{precoInicial.toFixed(2).replace('.', ',')}</span></>) : "Sob Consulta"}
                            </span>
                        </div>
                    </div>

                    <button onclick="window.enviarCarrinhoFinal(event)" class="w-full bg-[#25D366] hover:bg-[#20ba5a] text-white font-black py-5 rounded-2xl shadow-xl transition-all duration-300 flex justify-center items-center gap-4 text-xl uppercase">
                        <span id="btn-content" class="flex items-center gap-4">
                            <i class="fas fa-cart-plus"></i> 
                            <span>{temVariantes ? "Adicionar ao Orçamento" : "Solicitar Orçamento"}</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </section>
</LayoutBase>

<script is:inline define:vars={{ variants: prod.variants, slug: prod.slug, nome: prod.nome, codigo: prod.codigo, temVariantes }}>
    let currentSlide = 0;
    let precoAtual = temVariantes ? variants[0].price : 0;
    let corSelecionada = temVariantes ? variants[0].cor : "PADRÃO";
    let tamanhoSelecionado = temVariantes ? variants[0].tamanho : "ÚNICO";

    const activeClasses = ['border-mm-blue', 'text-mm-blue', 'bg-blue-50'];
    const inactiveClasses = ['border-gray-200', 'text-gray-400', 'bg-white'];

    // --- LÓGICA DO SLIDER ---
    if (!temVariantes) {
        const slidesImg = document.querySelectorAll('#slider-container img');
        const dots = document.querySelectorAll('.slider-dot');

        function showSlide(index) {
            if (slidesImg.length <= 1) return;
            if (index >= slidesImg.length) currentSlide = 0;
            else if (index < 0) currentSlide = slidesImg.length - 1;
            else currentSlide = index;

            slidesImg.forEach((img, i) => {
                img.style.opacity = i === currentSlide ? '1' : '0';
                img.style.zIndex = i === currentSlide ? '10' : '0';
                img.style.transform = i === currentSlide ? 'scale(1)' : 'scale(0.95)';
            });

            dots.forEach((dot, i) => {
                dot.classList.toggle('bg-mm-blue', i === currentSlide);
                dot.classList.toggle('w-8', i === currentSlide);
                dot.classList.toggle('bg-gray-300', i !== currentSlide);
            });
        }

        if (slidesImg.length > 1) {
            let inter = setInterval(() => showSlide(currentSlide + 1), 5000);
            document.getElementById('next-slide')?.addEventListener('click', () => { showSlide(currentSlide + 1); clearInterval(inter); });
            document.getElementById('prev-slide')?.addEventListener('click', () => { showSlide(currentSlide - 1); clearInterval(inter); });
        }
    }

    // --- LÓGICA DE CORES E BOTÕES ---
    window.mudarCor = function(cor, btn) {
        corSelecionada = cor;
        document.querySelectorAll('.color-btn').forEach(b => {
            b.classList.remove(...activeClasses);
            b.classList.add(...inactiveClasses);
        });
        btn.classList.add(...activeClasses);
        btn.classList.remove(...inactiveClasses);

        renderizarTamanhos(variants.filter(v => v.cor === cor));
    };

    window.mudarTamanho = function(v, btn) {
        tamanhoSelecionado = v.tamanho;
        precoAtual = v.price;
        document.querySelectorAll('.size-btn').forEach(b => {
            b.classList.remove(...activeClasses);
            b.classList.add(...inactiveClasses);
        });
        btn.classList.add(...activeClasses);
        btn.classList.remove(...inactiveClasses);
        
        const mainImg = document.getElementById('main-img');
        if(mainImg) mainImg.src = v.img;

        const priceEl = document.getElementById('display-price');
        if(priceEl) priceEl.innerText = precoAtual.toFixed(2).replace('.', ',');
        window.atualizarTotal();
    };

    function renderizarTamanhos(lista) {
        const container = document.getElementById('size-options');
        if(!container) return;
        container.innerHTML = '';
        lista.forEach((v, i) => {
            const btn = document.createElement('button');
            btn.innerText = v.tamanho;
            btn.className = `size-btn px-4 py-2 border-2 rounded-lg font-bold text-xs transition-all ${inactiveClasses.join(' ')}`;
            btn.onclick = () => window.mudarTamanho(v, btn);
            container.appendChild(btn);
            if(i === 0) window.mudarTamanho(v, btn);
        });
    }

    window.atualizarTotal = function() {
        if (!temVariantes) return;
        const qty = parseInt(document.getElementById('qty-input').value) || 1;
        const total = (precoAtual * qty).toFixed(2).replace('.', ',');
        const totalEl = document.getElementById('display-total');
        if(totalEl) totalEl.innerText = total;
    };

    // --- FUNÇÃO FINAL CORRIGIDA (Captura de foto robusta) ---
    window.enviarCarrinhoFinal = function(event) {
        const qty = parseInt(document.getElementById('qty-input').value) || 1;
        
        let imgFinal;
        if (temVariantes) {
            imgFinal = document.getElementById('main-img')?.src;
        } else {
            // Tenta pegar a imagem com opacidade 1, mas se o CSS falhar, pega a primeira do slider
            const imgAtiva = document.querySelector('#slider-container img[style*="opacity: 1"]');
            imgFinal = imgAtiva ? imgAtiva.src : document.querySelector('#slider-container img')?.src;
        }
        
        window.adicionarComVariacaoInterna?.(slug, nome, codigo, imgFinal, qty, `${corSelecionada} - ${tamanhoSelecionado}`, precoAtual);
        
        const btn = event.currentTarget;
        const old = btn.innerHTML;
        btn.style.backgroundColor = '#1489c8';
        btn.innerHTML = '<span><i class="fas fa-check"></i> SOLICITADO!</span>';
        setTimeout(() => { btn.style.backgroundColor = '#25D366'; btn.innerHTML = old; }, 1500);
    };

    if (temVariantes) {
        const firstBtn = document.querySelector('.color-btn');
        if(firstBtn) window.mudarCor(corSelecionada, firstBtn);
    }
</script>