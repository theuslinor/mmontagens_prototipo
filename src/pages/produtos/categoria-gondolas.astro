---
// src/pages/produtos/categoria-gondolas.astro
import LayoutBase from '../../layouts/LayoutBase.astro';
import { categorias } from '../../data/produtos.js';

// Filtramos a categoria de gôndolas
const categoria = categorias.find(cat => cat.id === 'gondolas');
const produtos = categoria ? categoria.items : [];
---

<LayoutBase title="Gôndolas - MM Montagens">
    <section class="w-full pt-6 pb-12 bg-white min-h-screen">
        <div class="container mx-auto px-6 lg:px-24">
            
            <div class="mb-2">
                <button 
                    onclick="history.back()" 
                    class="inline-flex items-center gap-3 text-gray-400 hover:text-mm-blue font-bold transition-all group text-xs uppercase tracking-[0.2em]"
                >
                    <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center group-hover:bg-blue-50 transition-colors shadow-sm">
                        <i class="fas fa-arrow-left"></i>
                    </div>
                    Voltar para categorias
                </button>
            </div>

            <div class="flex items-center gap-4 mb-12 border-b border-gray-100 pb-6">
                <i class="fas fa-store text-mm-blue text-2xl"></i>
                <h1 class="text-3xl font-black text-gray-900 uppercase tracking-tight">Nossas Gôndolas</h1>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
                {produtos.map(p => (
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col overflow-hidden group">
                        
                        <a 
                            href={`/produtos/${p.slug}`}
                            class="aspect-square bg-gray-50 p-8 flex items-center justify-center overflow-hidden relative card-image-container"
                            data-images={JSON.stringify(p.images && p.images.length > 0 ? p.images : [p.img])}
                        >
                            <img 
                                src={p.img} 
                                alt={p.nome} 
                                class="max-h-full object-contain mix-blend-multiply group-hover:scale-110 transition duration-500 card-main-img"
                                onerror="this.src='/midia/logo4.png'"
                            />
                        </a>
                        
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-black text-gray-900 text-lg mb-1 leading-tight uppercase">{p.nome}</h3>
                            <p class="text-[10px] font-bold text-gray-400 uppercase mb-4 tracking-widest italic">Projeto Personalizado</p>
                            
                            <div class="mt-auto flex items-center justify-between">
                                <span class="text-xl font-black text-mm-blue uppercase tracking-tight">
                                    A Combinar
                                </span>
                                <a 
                                    href={`/produtos/${p.slug}`} 
                                    class="bg-mm-blue hover:bg-mm-darkblue text-white px-5 py-2.5 rounded-lg font-bold text-sm transition-all shadow-md hover:shadow-lg"
                                >
                                    Ver Detalhes
                                </a>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            {produtos.length === 0 && (
                <div class="text-center py-20">
                    <p class="text-gray-400 font-bold italic">Nenhum modelo de gôndola cadastrado no momento.</p>
                </div>
            )}
        </div>
    </section>
</LayoutBase>

<style>
    /* Transição suave para a troca de imagens no card */
    .card-main-img {
        transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
    }
</style>

<script>
    // Lógica para rotacionar as imagens nos cards a cada 2 segundos
    const containers = document.querySelectorAll('.card-image-container');

    containers.forEach(container => {
        const images = JSON.parse(container.getAttribute('data-images') || '[]');
        const imgElement = container.querySelector('.card-main-img') as HTMLImageElement;

        if (images.length > 1 && imgElement) {
            let currentIndex = 0;

            setInterval(() => {
                // Efeito de fade out rápido
                imgElement.style.opacity = '0.3';

                setTimeout(() => {
                    currentIndex = (currentIndex + 1) % images.length;
                    // Troca o link da imagem (usa encodeURI para prevenir erro com espaços)
                    imgElement.src = encodeURI(images[currentIndex]);
                    
                    // Volta a opacidade
                    imgElement.style.opacity = '1';
                }, 500); // Metade do tempo da transição CSS
            }, 5000); // 2 segundos
        }
    });
</script>